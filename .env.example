# === REQUIRED ===

# Anthropic API Key — powers all 30 agents
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === DEPLOYMENT ===

# Frontend URL (set to your deployed frontend URL)
FRONTEND_URL=http://localhost:3000

# API URL (set to your deployed backend URL — used by bots + Make.com)
API_URL=http://localhost:8000

# Webhook secret for Make.com (optional, verifies incoming webhooks)
WEBHOOK_SECRET=

# === VIDEO GENERATION ===

# ElevenLabs — AI voiceover (https://elevenlabs.io)
ELEVENLABS_API_KEY=

# Kling AI — custom video scene generation (https://klingai.com)
KLING_API_KEY=

# Pexels — stock footage fallback, free (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Creatomate — video assembly + text overlays (https://creatomate.com)
CREATOMATE_API_KEY=

# === BOTS ===

# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Telegram bot token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# === NOTIFICATIONS ===

# Discord webhook URL for review notifications (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# Telegram chat ID for review notifications (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=

# Email for review notifications (optional)
NOTIFICATION_EMAIL=

# Generic webhook URL for Make.com/Zapier notifications (optional)
NOTIFICATION_WEBHOOK_URL=
