# V-Real AI — Environment Variables
# Copy this to .env and fill in your keys

# ── Required for agent system ──
ANTHROPIC_API_KEY=

# ── Required for video production ──
FAL_API_KEY=                    # fal.ai — Kling AI video + Flux 2 Pro images
ELEVENLABS_API_KEY=             # ElevenLabs — Julian voiceover
ASSEMBLYAI_API_KEY=             # AssemblyAI — caption generation

# ── Optional: Multi-model pressure testing ──
OPENAI_API_KEY=                 # ChatGPT pressure test
GEMINI_API_KEY=                 # Gemini pressure test
GROK_API_KEY=                   # Grok pressure test

# ── Optional: Make.com webhook URLs ──
MAKE_WEBHOOK_VOICEOVER=
MAKE_WEBHOOK_VIDEO=
MAKE_WEBHOOK_UPLOAD=
MAKE_WEBHOOK_THUMBNAIL=
MAKE_WEBHOOK_SEO=
MAKE_WEBHOOK_SHEETS=
MAKE_WEBHOOK_NOTIFY=
MAKE_WEBHOOK_ANALYTICS=
MAKE_WEBHOOK_SOCIAL=

# ── Optional: Make.com pressure test proxies ──
MAKE_WEBHOOK_PRESSURE_OPENAI=
MAKE_WEBHOOK_PRESSURE_GEMINI=
MAKE_WEBHOOK_PRESSURE_GROK=

# ── Optional: YouTube upload ──
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Optional: Stock footage ──
PEXELS_API_KEY=
