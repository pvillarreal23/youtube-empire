# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Webhook secret for Make.com (optional, for verifying incoming webhooks)
WEBHOOK_SECRET=

# Frontend URL (set this to your deployed frontend URL)
FRONTEND_URL=http://localhost:3000

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# API URL for bots to reach the backend (use deployed URL in production)
API_URL=http://localhost:8000

# ElevenLabs API key for AI voiceover (https://elevenlabs.io)
ELEVENLABS_API_KEY=

# Kling AI API key for custom video scene generation (https://klingai.com)
KLING_API_KEY=

# Pexels API key for stock footage fallback (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Creatomate API key for video assembly (https://creatomate.com)
CREATOMATE_API_KEY=

# Canva API key for thumbnails and branding (https://www.canva.com/developers/)
CANVA_API_KEY=
