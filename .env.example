# ──────────────────────────────────────────────
# YouTube Empire — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ─── Required ────────────────────────────────

# Your Anthropic API key.
# Get one at: https://console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────

# Enable the Managed Agents sandbox feature (default: true).
# Set to "false" to disable the sandbox dispatch UI and endpoints.
# MANAGED_AGENTS_ENABLED=true

# Claude model used for sandbox tasks (default: claude-sonnet-4-6).
# MANAGED_AGENTS_MODEL=claude-sonnet-4-6
