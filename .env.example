# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Webhook secret for Make.com (optional, for verifying incoming webhooks)
WEBHOOK_SECRET=

# Frontend URL (set this to your deployed frontend URL)
FRONTEND_URL=http://localhost:3000

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# API URL for bots to reach the backend (use deployed URL in production)
API_URL=http://localhost:8000
